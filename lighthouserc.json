{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/token-calculator/anthropic-claude-4-5-sonnet",
        "http://localhost:3000/about",
        "http://localhost:3000/privacy",
        "http://localhost:3000/pricing-data",
        "http://localhost:3000/network"
      ],
      "startServerCommand": "pnpm start",
      "startServerReadyPattern": "Ready in",
      "numberOfRuns": 1
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.9 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0 }]
      }
    },
    "_targetThresholds": {
      "comment": "Spec target is accessibility >= 0.95 and seo >= 0.95. Currently relaxed to 0.85/0.90 while we work through the long tail of audit failures (color contrast on the calculator UI, tap-target sizing < 48px, link-text descriptiveness). Tighten back up incrementally as fixes ship."
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
