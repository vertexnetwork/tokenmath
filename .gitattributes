# Normalize line endings to LF on checkout and in the index.
# Prettier writes LF (endOfLine: "lf"); this keeps git, CI, and editors aligned.
* text=auto eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf   binary

# Lockfile — never touch, but normalize EOL for diffs.
pnpm-lock.yaml text eol=lf merge=binary
