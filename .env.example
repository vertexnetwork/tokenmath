# tokenmath.dev — environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel for Production + Preview.

# --- Required ---

# Public site URL. Used by metadata, sitemap, JSON-LD, /api/og.
NEXT_PUBLIC_SITE_URL=https://tokenmath.dev

# --- Optional toggles ---

# Vercel Web Analytics. Set to "0" to disable; defaults to enabled.
NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Microsoft Clarity. If unset, the Clarity script never loads.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Ads ---

# Provider switch: 'none' | 'adsense' (default) | 'mediavine' | 'carbon'.
NEXT_PUBLIC_AD_PROVIDER=adsense

# Set when AdSense approves. Format: ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Per-placement AdSense slot IDs. Empty slot IDs render nothing.
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=
# NEXT_PUBLIC_ADSENSE_SLOT_PSEO_SIDEBAR=
# NEXT_PUBLIC_ADSENSE_SLOT_PSEO_AFTER_FAQ=

# Set when MediaVine approves.
# NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Set when Carbon Ads approves. Both IDs are required.
# NEXT_PUBLIC_CARBONADS_SERVE_ID=
# NEXT_PUBLIC_CARBONADS_PLACEMENT=

# --- Affiliates ---

# RunPod referral URL (cost-cut callout next to results). Format: https://runpod.io?ref=XXXX
# NEXT_PUBLIC_RUNPOD_REF_URL=

# --- Search engine verification (placeholders) ---

# Google Search Console / Bing Webmaster — fill in after first deploy.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=
