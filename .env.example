# tokenmath.dev — environment variables
# Copy to .env.local for local dev. Set the same keys in Vercel for Production + Preview.
# Spec: vertex-network-hub config/env.template.json

# --- Required identity (per spec §13) ---

NEXT_PUBLIC_SITE_NAME=tokenmath
NEXT_PUBLIC_SITE_SHORT_NAME=tokenmath
NEXT_PUBLIC_SITE_DOMAIN=tokenmath.dev
NEXT_PUBLIC_SITE_URL=https://tokenmath.dev
NEXT_PUBLIC_SITE_DESCRIPTION=Accurate token math for Claude, Gemini, and OpenAI. 100% client-side.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@tokenmath.dev

# --- Search engine verification ---

# Fill in after first deploy.
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# NEXT_PUBLIC_BING_SITE_VERIFICATION=

# --- Analytics ---

# Vercel Web Analytics + Speed Insights. Set to "0" to disable; defaults to enabled.
NEXT_PUBLIC_VERCEL_ANALYTICS=1

# Microsoft Clarity. Loaded only when set AND user has accepted consent.
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Optional alternates.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_GA_ID=

# --- Ads ---

# Provider switch: 'none' | 'adsense' | 'mediavine' | 'carbon'.
NEXT_PUBLIC_AD_PROVIDER=adsense

# Set when AdSense approves. Format: ca-pub-XXXXXXXXXXXXXXXX
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# Per-placement AdSense slot IDs. Empty slot IDs render nothing.
# NEXT_PUBLIC_ADSENSE_SLOT_HOME=
# NEXT_PUBLIC_ADSENSE_SLOT_PSEO_SIDEBAR=
# NEXT_PUBLIC_ADSENSE_SLOT_PSEO_AFTER_FAQ=

# Set when MediaVine approves.
# NEXT_PUBLIC_MEDIAVINE_SITE_ID=

# Set when Carbon Ads approves. Both IDs are required.
# NEXT_PUBLIC_CARBONADS_SERVE_ID=
# NEXT_PUBLIC_CARBONADS_PLACEMENT=

# --- Affiliate (single slot, generic) ---

# Per spec §10: one affiliate URL per site.
# Recommended partner (researched + double-verified 2026-06-23): PINECONE — pays CASH via
# PartnerStack (Stripe/PayPal, $50 min), ~10% of the customer's first year, no referral gate,
# tight audience fit (vector DB for RAG on Claude/Gemini/GPT). Apply at pinecone.io/partners;
# confirm the live commission %, cookie window, and threshold in the PartnerStack dashboard
# before publishing any rate. Paste your PartnerStack referral link below.
#   Bigger payout, looser fit: Bright Data (50% recurring, $25 min). Best topical fit but
#   one-time only: Vellum (30% first payment). Avoid Helicone/Langfuse/OpenRouter — no cash.
# NEXT_PUBLIC_AFFILIATE_URL=
# NEXT_PUBLIC_AFFILIATE_LABEL=Vector database for RAG — Pinecone
# NEXT_PUBLIC_AFFILIATE_PROVIDER=pinecone

# --- Email capture: LLM price-change alerts (Resend, opt-in) ---
# Set the client flag to 1 to render the PriceAlertForm; set both server keys for
# /api/subscribe to actually add contacts. All three must be present for the feature to work.

# NEXT_PUBLIC_EMAIL_ENABLED=0
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=

# --- Stripe (Pro tier, opt-in) ---

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PRO_ENABLED=0
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# --- Lemon Squeezy / Gumroad (opt-in) ---

# NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
# NEXT_PUBLIC_GUMROAD_PRODUCT_URL=
# NEXT_PUBLIC_GUMROAD_PRICE=

# --- Embed widget (opt-in) ---

# NEXT_PUBLIC_EMBED_ENABLED=0
